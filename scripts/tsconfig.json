{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@meal/shared": ["../packages/shared/src/index.ts"],
      "@meal/shared/*": ["../packages/shared/src/*"],
      "@meal/api/*": ["../apps/api/src/*"]
    }
  },
  "include": ["src/**/*", "../packages/shared/src/**/*", "../apps/api/src/db/**/*"]
}
