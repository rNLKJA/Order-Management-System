{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "moduleSuffixes": [".native", ".web", ""],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@meal/shared": ["../../packages/shared/src/index.ts"],
      "@meal/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
