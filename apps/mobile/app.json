{
  "expo": {
    "name": "订餐会员管理",
    "slug": "meal-membership",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mealmembership",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "locales": {
      "zh-Hans": "./locales/zh-Hans.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rnlkja.mealmembership",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "zh-Hans"
        ],
        "CFBundleDevelopmentRegion": "zh-Hans"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FAFC"
      },
      "package": "com.rnlkja.mealmembership"
    },
    "web": {
      "bundler": "metro",
      "output": "single-page-app",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://api.anshun-healthy-food.com",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7a9ccfc7-b24c-413a-ae82-e163d24b6653"
      }
    },
    "owner": "chuangyu_hscy"
  }
}
