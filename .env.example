# === 数据库（主库新加坡，副本东京） ===
TURSO_DATABASE_URL=libsql://meal-membership-xxx.turso.io
TURSO_AUTH_TOKEN=eyJ...

# === JWT（256-bit 随机：openssl rand -hex 32） ===
JWT_SECRET=change-me-to-64-hex-chars
JWT_EXPIRES_IN=7d

# === Cron 触发保护 ===
CRON_SECRET=change-me-to-64-hex-chars

# === Cloudflare R2 备份（Phase 4+ 才用到） ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=meal-membership-backup
R2_PUBLIC_BASE_URL=

# === Admin bootstrap（仅首次 seed 用；之后删除） ===
BOOTSTRAP_ADMIN_USERNAME=rNLKJA
BOOTSTRAP_ADMIN_PASSWORD=AmwBi990530

# === 时区（所有日期展示与 Cron 换算基准） ===
DEFAULT_TZ=Asia/Shanghai

# === 前端运行时（mobile / web） ===
#
# Expo 客户端读 API baseUrl 的优先级（见 apps/mobile/api/client.ts → getBaseUrl）：
#   1. EXPO_PUBLIC_API_BASE_URL（本文件 / EAS env）—— 开发与发版都优先走这条
#   2. apps/mobile/app.json → expo.extra.apiBaseUrl（Expo Go / 没读到 env 时的兜底）
#   3. 兜底 http://localhost:3000
#
# 配置指引：
#   • 本机 web/Expo Go：保持 http://localhost:3000。
#   • 真机调试（iOS/Android）：换成开发机局域网 IP，例如 http://192.168.1.10:3000，
#     否则手机的 localhost 指向的是它自己。
#   • 预发 / staging：填 staging 域名，覆盖 app.json 的生产地址。
#   • 正式发版：值在 apps/mobile/eas.json 的 build.preview / build.production.env 里显式声明，
#     当前生产为 https://api.anshun-healthy-food.com（CNAME 到 cname.vercel-dns.com，
#     绕开 *.vercel.app 在国内的 DNS 污染）。
#   • 改正式域名时三处一起改：app.json / eas.json / 本文件，保持一致避免漂移。
#
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
